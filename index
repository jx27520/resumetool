<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>简历适配小工具</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/lucide-static@0.294.0/font/style.min.css" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="bg-slate-900 text-white p-4 rounded-xl mb-6">
      <label class="block mb-2 text-sm">填入你的豆包 API Key（格式 AK:SK）</label>
      <input 
        type="password" 
        id="apiKey" 
        class="w-full p-2 rounded bg-slate-800 border border-slate-700 text-white"
        placeholder="AccessKeyID:SecretAccessKey"
      />
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <div>
        <label class="block mb-2 font-semibold">原始简历</label>
        <textarea id="oldResume" class="w-full h-32 p-3 rounded border border-slate-200" placeholder="粘贴你的旧简历"></textarea>
      </div>
      <div>
        <label class="block mb-2 font-semibold">新增经历（要生成CV段落用）</label>
        <textarea id="newExperience" class="w-full h-32 p-3 rounded border border-slate-200" placeholder="写你最近做的事"></textarea>
      </div>
    </div>

    <div class="mb-6">
      <label class="block mb-2 font-semibold">目标 JD</label>
      <textarea id="targetJD" class="w-full h-40 p-3 rounded border border-slate-200" placeholder="粘贴岗位要求"></textarea>
    </div>

    <button onclick="runAnalyze()" class="bg-indigo-600 text-white px-6 py-3 rounded-xl font-bold w-full">开始智能分析</button>

    <div id="result" class="mt-8 hidden">
      <div class="bg-emerald-50 p-6 rounded-xl border border-emerald-200 mb-6">
        <h3 class="font-bold text-xl mb-2">可直接复制进 CV 的新增经历段落</h3>
        <p id="cvParagraph" class="text-slate-800 leading-relaxed"></p>
      </div>

      <div class="bg-indigo-50 p-6 rounded-xl mb-6">
        <h3 class="font-bold mb-2">HR 理想画像</h3>
        <p id="targetPersona"></p>
      </div>

      <div class="bg-white p-6 rounded-xl mb-6">
        <h3 class="font-bold mb-2">可迁移能力</h3>
        <div id="transferableSkills" class="flex flex-wrap gap-2"></div>
      </div>

      <div class="bg-white p-6 rounded-xl mb-6">
        <h3 class="font-bold mb-4">简历话术优化建议</h3>
        <div id="rewriteSuggestions"></div>
      </div>

      <div class="bg-slate-900 text-slate-300 p-6 rounded-xl">
        <h3 class="font-bold mb-4">面试防守问题</h3>
        <div id="interviewPrep"></div>
      </div>
    </div>
  </div>

  <script>
    async function runAnalyze() {
      const apiKey = document.getElementById('apiKey').value.trim();
      const oldResume = document.getElementById('oldResume').value.trim();
      const newExperience = document.getElementById('newExperience').value.trim();
      const targetJD = document.getElementById('targetJD').value.trim();

      if (!apiKey || !targetJD) {
        alert('请填写 API Key 和 JD');
        return;
      }

      document.getElementById('result').classList.remove('hidden');

      const systemPrompt = `你是资深猎头、简历优化专家。
根据用户的【原始简历】、【新增经历】、【目标JD】，输出严格JSON，不要多余内容。
必须包含字段：
targetPersona,
transferableSkills (数组),
newExperienceCVParagraph (可直接放进简历的段落),
rewriteSuggestions (数组，每个含title,original,suggested,logic),
interviewPrep (数组，每个含question,strategy)
`;

      const userQuery = `
【原始简历】: ${oldResume}
【新增经历】: ${newExperience}
【目标JD】: ${targetJD}
`;

      try {
        const res = await fetch("https://ark.cn-beijing.volces.com/api/v3/chat/completions", {
          method: "POST",
          headers: {
            "Authorization": "Bearer " + apiKey,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            model: "doubao-pro-32k",
            messages: [
              { role: "system", content: systemPrompt },
              { role: "user", content: userQuery }
            ],
            response_format: { type: "json_object" }
          })
        });

        const data = await res.json();
        const result = JSON.parse(data.choices[0].message.content);

        document.getElementById('cvParagraph').innerText = result.newExperienceCVParagraph;
        document.getElementById('targetPersona').innerText = result.targetPersona;

        const skillDiv = document.getElementById('transferableSkills');
        skillDiv.innerHTML = '';
        result.transferableSkills.forEach(s => {
          skillDiv.innerHTML += `<span class="px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full text-sm">${s}</span>`;
        });

        const rewriteDiv = document.getElementById('rewriteSuggestions');
        rewriteDiv.innerHTML = '';
        result.rewriteSuggestions.forEach(item => {
          rewriteDiv.innerHTML += `
            <div class="mb-4 p-4 border rounded-lg">
              <h4 class="font-bold">${item.title}</h4>
              <p class="text-sm line-through text-slate-500">原：${item.original}</p>
              <p class="text-indigo-600 font-medium mt-1">改：${item.suggested}</p>
              <p class="text-xs text-slate-400 mt-1">逻辑：${item.logic}</p>
            </div>
          `;
        });

        const interviewDiv = document.getElementById('interviewPrep');
        interviewDiv.innerHTML = '';
        result.interviewPrep.forEach(q => {
          interviewDiv.innerHTML += `
            <div class="mb-4 pb-4 border-b border-slate-700">
              <p class="text-emerald-400 font-bold">Q：${q.question}</p>
              <p class="text-sm mt-1 pl-4 border-l border-slate-600">A：${q.strategy}</p>
            </div>
          `;
        });
      } catch (e) {
        alert("分析失败：" + e.message);
      }
    }
  </script>
</body>
</html>
