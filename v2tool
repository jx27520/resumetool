import React, { useState } from 'react';
import { 
  FileText, 
  Target, 
  Zap, 
  Copy, 
  Check, 
  Sparkles, 
  MessageSquare,
  ChevronRight
} from 'lucide-react';

const App = () => {
  const [data, setData] = useState({
    oldResume: '',
    newExperience: '',
    targetJD: ''
  });
  const [copied, setCopied] = useState(false);
  const [showPrompt, setShowPrompt] = useState(false);

  // 合成发给 Gemini 网页版的提示词
  const generatedPrompt = `你是一位拥有10年经验的资深求职教练。请基于以下信息，为我进行简历适配优化。

[任务目标]
1. 拆解目标岗位背后的HR核心痛点。
2. 将我的“新增经历”转化为一段符合STAR法则、可直接填入简历的专业描述。
3. 针对原始简历中不匹配的地方，给出话术平替建议。
4. 预判3个面试追问并给出高情商回答逻辑。

[我的原始简历片段]
${data.oldResume || '（未提供）'}

[我最近的新增经历]
${data.newExperience || '（未提供）'}

[目标岗位 JD]
${data.targetJD || '（未提供）'}

请以结构化、专业且富有启发性的方式回答。`;

  const handleCopy = () => {
    // 兼容性复制方法
    const textArea = document.createElement("textarea");
    textArea.value = generatedPrompt;
    document.body.appendChild(textArea);
    textArea.select();
    try {
      document.execCommand('copy');
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    } catch (err) {
      console.error('无法复制', err);
    }
    document.body.removeChild(textArea);
  };

  const isReady = data.targetJD.trim() !== '';

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 p-4 md:p-8 font-sans">
      <div className="max-w-4xl mx-auto">
        {/* 标题栏 */}
        <header className="text-center mb-10">
          <div className="inline-flex items-center justify-center p-3 bg-indigo-600 rounded-2xl shadow-lg mb-4">
            <Sparkles className="text-white w-8 h-8" />
          </div>
          <h1 className="text-3xl font-bold text-slate-800">简历适配提示词指挥部</h1>
          <p className="text-slate-500 mt-2">无需 API Key，一键生成最强 Prompt，直接投喂给 Gemini 网页版</p>
        </header>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* 输入区 */}
          <div className="space-y-6">
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
              <label className="flex items-center gap-2 font-bold mb-3 text-slate-700">
                <FileText className="w-5 h-5 text-indigo-500" /> 原始简历片段
              </label>
              <textarea 
                className="w-full h-32 p-4 bg-slate-50 rounded-xl border-none focus:ring-2 focus:ring-indigo-500 text-sm outline-none resize-none"
                placeholder="粘贴你旧简历中相关的部分..."
                value={data.oldResume}
                onChange={(e) => setData({...data, oldResume: e.target.value})}
              />
            </div>

            <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
              <label className="flex items-center gap-2 font-bold mb-3 text-slate-700">
                <Zap className="w-5 h-5 text-amber-500" /> 最近新增经历 (大白话)
              </label>
              <textarea 
                className="w-full h-32 p-4 bg-slate-50 rounded-xl border-none focus:ring-2 focus:ring-indigo-500 text-sm outline-none resize-none"
                placeholder="用你最熟悉的话描述：最近做了什么？学到了什么？"
                value={data.newExperience}
                onChange={(e) => setData({...data, newExperience: e.target.value})}
              />
            </div>
          </div>

          {/* JD区 */}
          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col">
            <label className="flex items-center gap-2 font-bold mb-3 text-slate-700">
              <Target className="w-5 h-5 text-rose-500" /> 目标岗位 JD (岗位描述)
            </label>
            <textarea 
              className="flex-grow min-h-[200px] w-full p-4 bg-slate-50 rounded-xl border-none focus:ring-2 focus:ring-indigo-500 text-sm outline-none resize-none"
              placeholder="在此处粘贴你想申请的职位要求..."
              value={data.targetJD}
              onChange={(e) => setData({...data, targetJD: e.target.value})}
            />
            <button 
              onClick={() => setShowPrompt(true)}
              disabled={!isReady}
              className="w-full mt-6 py-4 bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 text-white rounded-xl font-bold shadow-lg shadow-indigo-100 transition-all flex items-center justify-center gap-2"
            >
              生成高级提示词 <ChevronRight className="w-5 h-5" />
            </button>
          </div>
        </div>

        {/* 结果弹窗/区域 */}
        {showPrompt && (
          <div className="mt-10 animate-in fade-in slide-in-from-bottom-4 duration-500">
            <div className="bg-slate-800 rounded-3xl p-8 shadow-2xl relative overflow-hidden">
              <div className="absolute top-0 right-0 p-4 opacity-10">
                <MessageSquare className="w-32 h-32 text-white" />
              </div>
              
              <div className="relative z-10">
                <div className="flex items-center justify-between mb-6">
                  <h3 className="text-white font-bold text-xl flex items-center gap-2">
                    <Sparkles className="text-indigo-400 w-6 h-6" /> 已为您准备好 Prompt
                  </h3>
                  <button 
                    onClick={handleCopy}
                    className={`flex items-center gap-2 px-4 py-2 rounded-full font-medium transition-all ${copied ? 'bg-emerald-500 text-white' : 'bg-white text-slate-800 hover:bg-indigo-50'}`}
                  >
                    {copied ? <><Check className="w-4 h-4" /> 已复制</> : <><Copy className="w-4 h-4" /> 点击一键复制</>}
                  </button>
                </div>

                <div className="bg-slate-900/50 border border-slate-700 rounded-2xl p-6 text-slate-300 text-sm font-mono whitespace-pre-wrap max-h-80 overflow-y-auto leading-relaxed">
                  {generatedPrompt}
                </div>

                <div className="mt-6 flex flex-col md:flex-row items-center gap-4 text-slate-400 text-xs">
                  <span className="flex items-center gap-1"><Check className="w-3 h-3 text-emerald-500" /> 无需 API 密钥</span>
                  <span className="flex items-center gap-1"><Check className="w-3 h-3 text-emerald-500" /> 隐私本地保存</span>
                  <span className="flex items-center gap-1"><Check className="w-3 h-3 text-emerald-500" /> 适配 Gemini/GPT/Claude</span>
                </div>
              </div>
            </div>
            
            <div className="mt-6 text-center text-slate-500 text-sm">
              <p>复制后，直接前往 <a href="https://gemini.google.com" target="_blank" className="text-indigo-600 font-bold underline">Gemini 官网</a> 粘贴并发送即可得到完美分析。</p>
            </div>
          </div>
        )}
      </div>
    </div>
  );
};

export default App;
